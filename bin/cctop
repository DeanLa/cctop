#!/bin/bash
# cctop — sessions dashboard for Claude Code and Codex

PLUGIN_SCRIPTS_DIR="$(find "${HOME}/.claude/plugins/cache/cctop" -type d -name scripts -maxdepth 4 2>/dev/null | head -1)"
STANDALONE_SCRIPTS_DIR="${HOME}/.local/share/cctop/scripts"

if [ -n "$PLUGIN_SCRIPTS_DIR" ] && [ -x "$PLUGIN_SCRIPTS_DIR/launch-cctop.sh" ]; then
    exec "$PLUGIN_SCRIPTS_DIR/launch-cctop.sh" "$@"
fi

if [ -x "$STANDALONE_SCRIPTS_DIR/launch-cctop.sh" ]; then
    exec "$STANDALONE_SCRIPTS_DIR/launch-cctop.sh" "$@"
fi

echo "cctop: runtime not found." >&2
echo "Install with ./install.sh --prod or ./install.sh --dev" >&2
exit 1
